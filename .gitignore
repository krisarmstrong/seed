# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║ Seed - .gitignore                                                         ║
# ╠═══════════════════════════════════════════════════════════════════════════╣
# ║ Network testing and automation platform                                   ║
# ║ Stack: Go (backend), TypeScript/React (UI), Storybook                    ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# ─── Go Binaries ─────────────────────────────────────────────────────────────
/seed
/seed-*
*.exe
*.exe~
*.dll
*.so
*.dylib

# ─── Build Directories ───────────────────────────────────────────────────────
/dist/
/bin/
/build/

# ─── Go Testing & Coverage ───────────────────────────────────────────────────
*.test
*.out
coverage.html
coverage.txt

# ─── Go Workspace & Dependencies ─────────────────────────────────────────────
go.work
go.work.sum
vendor/

# Go build caches
.gocache/
.gomodcache/
.golangci-cache/

# ─── Frontend (UI) ───────────────────────────────────────────────────────────
# Dependencies
ui/node_modules/
node_modules/

# Build outputs
ui/dist/
ui/.vite/
ui/coverage/

# Storybook
*storybook.log
storybook-static/

# Playwright test results
ui/playwright-report/
ui/test-results/

# TypeScript
*.tsbuildinfo

# Logs
npm-debug.log*
yarn-error.log*
*.log

# ─── Environment & Secrets ───────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key
*.crt

# Certificates (generated at runtime)
certs/
!certs/.gitkeep
ui/certs/

# ─── Configuration Overrides ─────────────────────────────────────────────────
# Local config overrides (defaults should be tracked)
configs/*.local.yaml
configs/*.local.json
config.yaml

# ─── Database & Runtime Data ─────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# Auto-generated or downloaded data
data/

# ─── Logs ────────────────────────────────────────────────────────────────────
logs/

# ─── Temporary Files ─────────────────────────────────────────────────────────
tmp/
temp/
*.tmp
.tmp_*
*~

# ─── Build & Package Artifacts ───────────────────────────────────────────────
*.tar.gz
*.zip
*.deb
*.rpm

# ─── Debug & Development ─────────────────────────────────────────────────────
# Debug output images
DebugImages/

# Screenshot artifacts
*.png

# ─── AI/Agent Artifacts ──────────────────────────────────────────────────────
# Claude, Gemini, and other AI tool artifacts
.claude/settings.local.json
.gemini/
CLAUDE.md

# Workspace files
*.code-workspace
.ignore

# ─── Documentation Exclusions ────────────────────────────────────────────────
# Internal planning docs (use GitHub issues/projects instead)
docs/internal/
docs/AI_*.md
docs/*_PLAN.md
docs/WIKI_CONTENT.md
docs/DOCUMENTATION_STRUCTURE.md
docs/issues*.md

# Root-level planning files
/*_PLAN.md
/issue*.md
