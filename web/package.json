{
  "name": "seed-web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=25.2.1"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:strict": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --reporter=verbose",
    "test:watch": "vitest --reporter=dot",
    "test:coverage": "vitest run --coverage --reporter=verbose",
    "test:e2e": "playwright test --reporter=list",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "size": "size-limit",
    "size:why": "size-limit --why",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/jszip": "^3.4.0",
    "i18next": "^25.7.3",
    "i18next-browser-languagedetector": "^8.2.0",
    "i18next-http-backend": "^3.0.2",
    "jszip": "^3.10.1",
    "lucide-react": "^0.561.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-i18next": "^16.5.0",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.3",
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.57.0",
    "@size-limit/preset-app": "^11.1.6",
    "@storybook/addon-a11y": "^10.1.8",
    "@storybook/addon-actions": "^9.0.8",
    "@storybook/addon-docs": "^10.1.8",
    "@storybook/addon-onboarding": "^10.1.8",
    "@storybook/addon-vitest": "^10.1.8",
    "@storybook/react-vite": "^10.1.8",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.2.7",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/browser-playwright": "^4.0.15",
    "@vitest/coverage-v8": "^4.0.15",
    "eslint": "^9.39.2",
    "eslint-plugin-jsdoc": "^61.5.0",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "^0.4.25",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-storybook": "^10.1.8",
    "globals": "^16.5.0",
    "jsdom": "^27.3.0",
    "json-schema-to-zod": "^2.7.0",
    "lint-staged": "^16.2.7",
    "playwright": "^1.57.0",
    "postcss": "^8.4.49",
    "prettier": "^3.7.4",
    "size-limit": "^11.1.6",
    "storybook": "^10.1.8",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0",
    "vite": "^7.2.7",
    "vitest": "^4.0.15"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "size-limit": [
    {
      "name": "Main bundle (JS)",
      "path": "dist/assets/index-*.js",
      "limit": "300 KB",
      "gzip": true
    },
    {
      "name": "Styles (CSS)",
      "path": "dist/assets/index-*.css",
      "limit": "50 KB",
      "gzip": true
    }
  ]
}
