[Unit]
Description=The Seed - Development
Documentation=https://github.com/krisarmstrong/seed
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=krisarmstrong
Group=krisarmstrong
WorkingDirectory=/home/krisarmstrong/seed
ExecStartPre=+/usr/sbin/setcap cap_net_raw,cap_net_admin=+ep /home/krisarmstrong/seed/seed
ExecStart=/home/krisarmstrong/seed/seed
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

# Environment
Environment=HOME=/home/krisarmstrong

[Install]
WantedBy=multi-user.target
