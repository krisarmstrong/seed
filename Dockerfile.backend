# Backend-only build for testing Apple container CLI
FROM golang:1.25-alpine

WORKDIR /app

# Install build dependencies
RUN apk add --no-cache gcc musl-dev libpcap-dev

# Copy go mod files
COPY go.mod go.sum ./
RUN go mod download

# Copy source code
COPY cmd/ ./cmd/
COPY internal/ ./internal/

# Build the binary
RUN CGO_ENABLED=1 GOOS=linux go build -o netscope ./cmd/netscope

# Expose port
EXPOSE 8080

CMD ["./netscope"]
