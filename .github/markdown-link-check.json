{
  "ignorePatterns": [
    {
      "pattern": "^http://localhost"
    },
    {
      "pattern": "^https://192.168"
    },
    {
      "pattern": "^http://192.168"
    },
    {
      "pattern": "^https://<device-ip>"
    },
    {
      "pattern": "^http://<device-ip>"
    },
    {
      "pattern": "^https://github.com/krisarmstrong/seed/(commit|commits|compare)"
    }
  ],
  "replacementPatterns": [
    {
      "pattern": "^/",
      "replacement": "{{BASEURL}}/"
    }
  ],
  "httpHeaders": [
    {
      "urls": ["https://github.com", "https://raw.githubusercontent.com"],
      "headers": {
        "Accept-Encoding": "zstd, br, gzip, deflate"
      }
    }
  ],
  "timeout": "20s",
  "retryOn429": true,
  "retryCount": 3,
  "fallbackRetryDelay": "30s",
  "aliveStatusCodes": [200, 206, 0]
}
