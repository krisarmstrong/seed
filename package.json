{
  "name": "netscope",
  "version": "0.0.0",
  "private": true,
  "description": "Portable Network Diagnostic Tool",
  "scripts": {
    "prepare": "husky",
    "format:md": "prettier --write \"**/*.md\" --ignore-path .gitignore",
