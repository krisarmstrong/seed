#!/usr/bin/env sh

# Skip hooks in CI
[ -n "$CI" ] && exit 0

echo "Running pre-commit checks..."

# Track if any checks fail
FAILED=0

# Get staged files
STAGED_GO_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' || true)
STAGED_WEB_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '^web/' || true)
STAGED_MD_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.md$' || true)

# ============================================
# Markdown Formatting Check
# ============================================
if [ -n "$STAGED_MD_FILES" ]; then
  echo ""
  echo "=== Markdown Formatting Check ==="

  if command -v npx >/dev/null 2>&1 && [ -f "node_modules/.bin/prettier" ]; then
    echo "Checking markdown formatting..."
    if ! npx prettier --check $STAGED_MD_FILES 2>/dev/null; then
      echo "Markdown formatting issues found! Run 'npm run format:md' to fix."
      FAILED=1
    else
      echo "Markdown formatting OK"
    fi
  else
    echo "Prettier not installed, skipping markdown check"
  fi
fi

# ============================================
# Go Backend Checks
# ============================================
if [ -n "$STAGED_GO_FILES" ]; then
  echo ""
  echo "=== Go Backend Checks ==="

  # Find golangci-lint (check PATH and common locations)
  GOLANGCI_LINT=""
  if command -v golangci-lint >/dev/null 2>&1; then
    GOLANGCI_LINT="golangci-lint"
  elif [ -x "$HOME/go/bin/golangci-lint" ]; then
    GOLANGCI_LINT="$HOME/go/bin/golangci-lint"
  elif [ -x "$(go env GOPATH)/bin/golangci-lint" ]; then
    GOLANGCI_LINT="$(go env GOPATH)/bin/golangci-lint"
  fi

  # Run Go linting (if golangci-lint is found)
  if [ -n "$GOLANGCI_LINT" ]; then
    echo "Running Go linter..."
    if ! $GOLANGCI_LINT run --new-from-rev=HEAD~1 2>/dev/null; then
      echo "Go linting failed!"
      FAILED=1
    fi
  else
    echo "golangci-lint not installed, skipping Go linting"
    echo "  Install with: make tools"
  fi

  # Run Go tests (short mode for speed)
  echo "Running Go tests..."
  if ! go test -short ./... 2>&1 | tail -20; then
    echo "Go tests failed!"
    FAILED=1
  fi
fi

# ============================================
# Frontend Checks
# ============================================
if [ -n "$STAGED_WEB_FILES" ]; then
  echo ""
  echo "=== Frontend Checks ==="

  # Check if web/node_modules exists
  if [ ! -d "web/node_modules" ]; then
    echo "Frontend dependencies not installed. Run: cd web && npm install"
    FAILED=1
  else
    # Run frontend linting via lint-staged
    if [ -f "web/node_modules/.bin/lint-staged" ]; then
      echo "Running frontend linting..."
      cd web
      echo "Current directory: $(pwd)"
      echo "Files in current directory:"
      ls -l
      if ! npx lint-staged 2>&1; then
        echo "Frontend linting failed!"
        FAILED=1
      fi
      cd ..
    fi

    # Run frontend tests
    echo "Running frontend tests..."
    cd web
    if ! npm test 2>&1 | tail -15; then
      echo "Frontend tests failed!"
      FAILED=1
    fi
    cd ..
  fi
fi

# ============================================
# Final Result
# ============================================
echo ""
if [ $FAILED -ne 0 ]; then
  echo "Pre-commit checks FAILED. Please fix the issues above."
  exit 1
fi

echo "All pre-commit checks passed!"
exit 0