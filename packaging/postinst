#!/bin/bash
# =============================================================================
# The Seed - Post-installation Script
# =============================================================================
# Creates service user, sets capabilities, and starts the service.
# =============================================================================
set -e

INSTALL_DIR="/usr/local/seed"
SERVICE_USER="seed"
SERVICE_GROUP="seed"
BINARY_PATH="/usr/local/bin/seed"

# Create service user and group if they don't exist
if ! getent group "$SERVICE_GROUP" > /dev/null 2>&1; then
    echo "Creating group: $SERVICE_GROUP"
    groupadd --system "$SERVICE_GROUP"
fi

if ! getent passwd "$SERVICE_USER" > /dev/null 2>&1; then
    echo "Creating user: $SERVICE_USER"
    useradd --system --gid "$SERVICE_GROUP" --home-dir "$INSTALL_DIR" --shell /usr/sbin/nologin "$SERVICE_USER"
fi

# Create directories
mkdir -p "$INSTALL_DIR/configs"
mkdir -p "$INSTALL_DIR/logs"
chown -R "$SERVICE_USER:$SERVICE_GROUP" "$INSTALL_DIR"

# Copy default config if not exists
if [[ ! -f "$INSTALL_DIR/configs/seed.yaml" ]] && [[ -f "/etc/seed/seed.yaml" ]]; then
    cp /etc/seed/seed.yaml "$INSTALL_DIR/configs/"
    chown "$SERVICE_USER:$SERVICE_GROUP" "$INSTALL_DIR/configs/seed.yaml"
fi

# Set capabilities for raw socket access (required for network diagnostics)
if command -v setcap &> /dev/null; then
    setcap cap_net_raw=+ep "$BINARY_PATH" || echo "Warning: Could not set capabilities"
else
    echo "Warning: setcap not found. Install libcap2-bin for non-root operation."
fi

# Reload systemd and enable service
systemctl daemon-reload
systemctl enable seed.service

# Start service
systemctl start seed.service || true

echo ""
echo "The Seed installed successfully!"
echo ""
echo "Commands:"
echo "  View logs:      journalctl -u seed -f"
echo "  Restart:        systemctl restart seed"
echo "  Status:         systemctl status seed"
echo ""

exit 0
