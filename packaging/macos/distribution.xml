<?xml version="1.0" encoding="utf-8" standalone="no"?>
<installer-gui-script minSpecVersion="2">
    <title>The Seed - Network Diagnostic Tool</title>
    <organization>com.mustardseednetworks</organization>
    <domains enable_localSystem="true"/>
    <options customize="never" require-scripts="true" rootVolumeOnly="true"/>

    <!-- Minimum macOS version (Monterey 12.0 or later) -->
    <os-version min="12.0"/>

    <!-- Welcome screen text -->
    <welcome file="welcome.html"/>

    <!-- License (optional) -->
    <!-- <license file="license.txt"/> -->

    <!-- Conclusion screen text -->
    <conclusion file="conclusion.html"/>

    <!-- Package reference -->
    <pkg-ref id="com.seed.pkg"/>

    <choices-outline>
        <line choice="default">
            <line choice="com.seed.pkg"/>
        </line>
    </choices-outline>

    <choice id="default"/>

    <choice id="com.seed.pkg" visible="false">
        <pkg-ref id="com.seed.pkg"/>
    </choice>

    <pkg-ref id="com.seed.pkg" version="__VERSION__" onConclusion="none">seed-component.pkg</pkg-ref>

</installer-gui-script>
